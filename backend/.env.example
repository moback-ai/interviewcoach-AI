# ── Database ──────────────────────────────────────────
DB_HOST=YOUR_DB_PRIVATE_IP
DB_PORT=5432
DB_NAME=interview_db
DB_USER=interview_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── JWT Auth ───────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# ── App ────────────────────────────────────────────────
DOMAIN=https://ugaanlabs.ai
STORAGE_PATH=/apps/storage
PUBLIC_STORAGE_URL=https://ugaanlabs.ai/storage

# ── AI ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Whisper ────────────────────────────────────────────
WHISPER_MODEL=base

# ── Upload ─────────────────────────────────────────────
UPLOAD_FOLDER=/apps/storage
MAX_CONTENT_MB=200

# ── Internal API ──────────────────────────────────────────
BACKEND_API_BASE=http://127.0.0.1:5000

# Database connection pool size
DB_POOL_MIN=2
DB_POOL_MAX=20
