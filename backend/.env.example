# ── Database ──────────────────────────────────────────
DB_HOST=YOUR_DB_PRIVATE_IP
DB_PORT=5432
DB_NAME=interview_db
DB_USER=interview_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── JWT Auth ───────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# ── App ────────────────────────────────────────────────
DOMAIN=https://yourdomain.com
STORAGE_PATH=/apps/storage
PUBLIC_STORAGE_URL=https://yourdomain.com/storage

# ── AI ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Whisper ────────────────────────────────────────────
WHISPER_MODEL=base

# ── Upload ─────────────────────────────────────────────
UPLOAD_FOLDER=/apps/storage
MAX_CONTENT_MB=200
